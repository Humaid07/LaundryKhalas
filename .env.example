# =========================================================
# LaundryKhalas WhatsApp Agent - environment configuration
# Copy to .env and fill in for local development.
# NEVER commit a real .env file.
# =========================================================

# --- App ---
APP_ENV=local
APP_DEBUG=true
APP_NAME=laundrykhalas-whatsapp-agent
API_PREFIX=/api
# Comma-separated browser origins allowed to call the API (admin UI dev server).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=laundrykhalas
POSTGRES_USER=laundrykhalas
POSTGRES_PASSWORD=changeme_local_only
DATABASE_URL=postgresql+asyncpg://laundrykhalas:changeme_local_only@postgres:5432/laundrykhalas

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Security ---
# Shared secret admin endpoints check for (placeholder auth for MVP only).
ADMIN_API_KEY=changeme_local_admin_key

# --- LLM Gateway ---
# Only "mock" is safe/enabled by default. anthropic/openai are stubs until
# explicitly enabled here AND given real keys - never enabled in this task.
LLM_DEFAULT_PROVIDER=mock
LLM_ENABLE_ANTHROPIC=false
LLM_ENABLE_OPENAI=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MAX_TOKENS_PER_CALL=1024
LLM_MAX_TOOL_STEPS=10

# --- WhatsApp Channel ---
# Only "mock" is implemented/enabled in this task.
WHATSAPP_PROVIDER=mock
META_WHATSAPP_ENABLED=false
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WABA_ID=
META_WHATSAPP_VERIFY_TOKEN=

# --- Cost ceilings (placeholders enforced/read via Redis) ---
COST_MAX_TOOL_STEPS_PER_RUN=10
COST_MAX_TOKENS_PER_MESSAGE=2000
COST_MAX_TOKENS_PER_CONVERSATION_PER_DAY=20000
COST_MAX_SPEND_PER_CUSTOMER_PER_DAY_USD=5.00
COST_MAX_GLOBAL_SPEND_PER_DAY_USD=200.00
