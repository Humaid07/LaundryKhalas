APP_ENV=development
APP_NAME=LaundryKhalas WhatsApp Agent
AGENT_MODE=standalone

# --- Database mode / environment (DEV/TEST Supabase project) ---
# This backend can run against local SQLite (default) or the SEPARATE dev/test
# Supabase project. It is NEVER production. A production Supabase project is
# created later with its own config.
#   DATABASE_MODE=sqlite   -> local SQLite (default, safe placeholder here)
#   DATABASE_MODE=supabase -> dev/test Supabase Postgres (set DATABASE_URL below)
DATABASE_ENV=test
DATABASE_MODE=sqlite
SUPABASE_PROJECT_TYPE=test
# Seed/reset scripts refuse to run unless these are explicitly true (and the
# env is a confirmed dev/test project). Keep false by default.
ALLOW_TEST_SEED=false
ALLOW_TEST_RESET=false

# Supabase connection (dev/test project). Fill these in your local .env ONLY.
# DATABASE_URL is the backend-only Postgres connection string (session pooler
# or direct). SUPABASE_SERVICE_ROLE_KEY is BACKEND-ONLY — never expose it to the
# frontend. The dashboard talks to FastAPI, never to Supabase directly.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=

# Humanized typing indicator. The chat UI holds an "agent is typing..." bubble
# for a natural delay before showing the reply (random between min and max).
# The backend does not block on these - it only publishes them via
# /api/settings/status; the delay is enforced in the frontend.
AGENT_MIN_TYPING_DELAY_MS=2000
AGENT_MAX_TYPING_DELAY_MS=3000

WHATSAPP_MODE=mock
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=

# Local SQLite (DATABASE_MODE=sqlite). For DATABASE_MODE=supabase, replace this
# with the dev/test Supabase Postgres connection string, e.g.
#   DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./whatsapp_agent.db

# NOTE: apps/admin (the main system's admin dashboard) already uses port
# 3000. This standalone agent's chat UI (apps/whatsapp-chat) runs on 3100
# instead so both can run side by side - see docs/architecture/
# standalone-whatsapp-agent.md for why. Update this if you change that port.
ALLOWED_ORIGINS=http://localhost:3100,http://127.0.0.1:3100,http://localhost:3000,http://127.0.0.1:3000
