# Copy to .env.local for local development.
# Base URL the BROWSER uses to reach the FastAPI backend (client-side fetches only).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Placeholder admin auth - must match the backend's ADMIN_API_KEY.
NEXT_PUBLIC_ADMIN_API_KEY=changeme_local_admin_key
# Standalone WhatsApp Agent backend (apps/whatsapp-agent) used by the
# Operations → WhatsApp Agent tab. Defaults to :8100 if unset.
NEXT_PUBLIC_WHATSAPP_AGENT_API_URL=http://localhost:8100
