# Copy to .env.local for local development.
#
# AUTH / RBAC: the dashboard authenticates against the FastAPI backend
# (apps/whatsapp-agent) at NEXT_PUBLIC_WHATSAPP_AGENT_API_URL — it POSTs to
# /api/auth/login, stores the returned JWT, and sends it as `Authorization:
# Bearer <token>` on guarded /api/* calls (incl. admin user management via
# /api/users). There is NO frontend API key. To require login, set the BACKEND's
# REQUIRE_AUTH=true + JWT_SECRET (and DATABASE_MODE=supabase so the users table
# exists); with REQUIRE_AUTH=false the backend admits a synthetic dev admin.
#
# Standalone WhatsApp Agent backend (apps/whatsapp-agent). The dashboard talks
# to FastAPI ONLY — never to Supabase directly. Defaults to :8100 if unset;
# the current Evolution live-test backend runs on :8101.
NEXT_PUBLIC_WHATSAPP_AGENT_API_URL=http://localhost:8101
#
# Legacy — only for the old app/ backend's shared-key admin routes (X-Admin-Api-Key).
# NOT used by the JWT auth flow above; leave unset unless you run the legacy app/.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_ADMIN_API_KEY=changeme_local_admin_key
# Live WhatsApp data flag. When true, /operations/customer-orders and
# /operations/customer-facing render extra LIVE panels that fetch real
# orders/conversations/flags from the agent backend (Dashboard → FastAPI →
# Supabase). Off/unset → only the existing demo surfaces render.
NEXT_PUBLIC_USE_LIVE_WHATSAPP_INBOX=true
